#!/usr/bin/env bun

const main = async () => {
  // Replace this URL with the actual StreamEndpoint from your CloudFormation outputs
  const url = 'http://localhost:3008/v1/stream';
  
  console.log(`Testing streaming endpoint: ${url}`);
  
  const response = await fetch(url, {
    method: 'GET',
    headers: {
      'Accept': 'text/event-stream'
    }
  });
  
  if (!response.ok) {
    console.error(`Error: ${response.status} ${response.statusText}`);
    const text = await response.text();
    console.error(`Response body: ${text}`);
    return;
  }
  
  console.log('Stream connected, receiving data...');
  
  // Use a proper text decoder for the stream
  const reader = response.body.getReader();
  const decoder = new TextDecoder();
  
  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    const text = decoder.decode(value, { stream: true });
    console.log(`Received chunk: ${text}`);
  }
  
  console.log('Stream completed');
}

main().catch(error => console.error('Error:', error));
