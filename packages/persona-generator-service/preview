#!/usr/bin/env bun

import { api } from './src/service';

const port = 3008;

console.log(`Starting server on port ${port}...`);

Bun.serve({
  fetch: api.fetch,
  port: Number(port),
  development: process.env.NODE_ENV !== 'production',
});

console.log(`Server running at http://localhost:${port}`);
