{
  "name": "@fleek-platform/persona-generator",
  "version": "0.0.1",
  "description": "The persona-generator is a library designed to transform user input into structured JSON files representing AI agent personas. It converts user friendly descriptions into detailed character profiles",
  "bin": {
    "persona-generator": "cli"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./PersonaGenerator": "./dist/index.js"
  },
  "scripts": {
    "build": "bunx bun build.ts",
    "changeset:add": "bunx changeset",
    "changeset:status": "bunx changeset status",
    "changeset:version": "bunx changeset version",
    "clean": "bun clean:dist && bun clean:node",
    "clean:dist": "rm -rf dist",
    "clean:node": "rm -rf node_modules",
    "lambda:preview": "bun build && LAMBDA_RUNNER_MODE=\"dist\" sls dev",
    "lambda:deploy": "bun build && LAMBDA_RUNNER_MODE=\"dist\" sls deploy",
    "format": "bunx biome format --write ./src",
    "format:check": "bunx biome format ./src",
    "preview": "bunx bun --watch ./preview",
    "transpile": "pnpm exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@changesets/cli": "^2.28.1",
    "@fleek-platform/agents-ui": "7.30.0-rc.1",
    "@types/bun": "^1.2.5",
    "abort-controller": "^3.0.0",
    "biome": "^0.3.3",
    "bun": "^1.2.7",
    "hono": "^4.7.5",
    "node-fetch": "^3.3.2",
    "openai": "4.90.0",
    "serverless-domain-manager": "^8.0.0",
    "zod": "^3.23.4"
  },
  "engines": {
    "bun": ">=1.2.7",
    "pnpm": ">=9",
    "node": ">=20.18.0"
  },
  "devDependencies": {
    "serverless-vpc-plugin": "^1.0.6",
    "typescript": "^5.8.3"
  }
}
