#!/bin/bash

echo "🤖 Development deployment..."

dotEnvFilename=".env"
deployOptions=""

if [[ -z "$CI" && ! -f "$dotEnvFilename" ]]; then
  echo "👹 Oops! A dotenv file ($dotEnvFilename) wasn't found."

  exit 1
else
  source "$dotEnvFilename"
fi

if [[ "$PUBLIC_PERSONA_GENERATOR_ENVIRONMENT" == "staging" || "$PUBLIC_PERSONA_GENERATOR_ENVIRONMENT" == "production" ]]; then
  STACK_NAME="$PRIVATE_STACK_NAME_PREFIX-$PUBLIC_PERSONA_GENERATOR_ENVIRONMENT"
else
  echo "👹 Oops! Unknown environment PUBLIC_PERSONA_GENERATOR_ENVIRONMENT = $PUBLIC_PERSONA_GENERATOR_ENVIRONMENT"

  exit 1
fi

if [[ ! -z "$CI" ]]; then
  deployOptions="--no-confirm-changeset"
fi

sam deploy \
  --stack-name "$STACK_NAME" \
  "$deployOptions" \
  --parameter-overrides \
    Environment="$PUBLIC_PERSONA_GENERATOR_ENVIRONMENT" \
    CertificateArn="$PUBLIC_PERSONA_GENERATOR_CERTIFICATE_ARN" \
    DomainName="$PUBLIC_PERSONA_GENERATOR_CUSTOM_DOMAIN_NAME" \
    PrivateOpenAIApiKey="$PRIVATE_OPENAI_COMPATIBLE_API_KEY" \
    PublicOpenAIApiUrl="$PUBLIC_OPENAI_COMPATIBLE_API_URL" \
    PublicOpenAIModel="$PUBLIC_OPENAI_COMPATIBLE_MODEL" \
    PublicFleekRestApiUrl="$PUBLIC_FLEEK_REST_API_URL" \
  --capabilities CAPABILITY_IAM
