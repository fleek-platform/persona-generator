{
  "name": "persona-generator-monorepo",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build:libs": "bun run build:persona-generator",
    "build:persona-generator": "bun --filter \"./packages/persona-generator\" build",
    "dev": "scripts/dev-watcher",
    "service:build": "sam build --build-in-source --parameter-overrides Environment=staging",
    "service:deploy": "bun run service:build && ./scripts/dev-deploy",
    "service:logs": "sam logs -n PersonaGeneratorService --tail",
    "service:validate": "sam validate",
    "service:info": "sam list resources",
    "format": "bun --filter \"./packages/persona-generator\" format",
    "lint:serverless": "./scripts/dev-lint-serverless"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  }
}
