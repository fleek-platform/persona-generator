{
  "name": "persona-generator-monorepo",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "scripts/dev-watcher",
    "service:build": "sam build --build-in-source --parameter-overrides Environment=staging",
    "service:deploy": "bun run service:build && ./scripts/dev-deploy",
    "service:logs": "sam logs -n PersonaGeneratorService --stack-name persona-generator-test-service --tail",
    "service:validate": "sam validate",
    "service:info": "sam list resources"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  }
}
